# =============================================================================
# Variáveis de ambiente do SeedCode
# -----------------------------------------------------------------------------
# Copie este arquivo para `.env.local` e preencha os valores.
# =============================================================================

# Segredo usado pelo NextAuth para assinar os tokens de sessão (JWT).
# Gere um valor seguro com:  npx auth secret   (ou)  openssl rand -base64 32
AUTH_SECRET="troque-por-um-segredo-aleatorio"

# --- OAuth Google (opcional) -------------------------------------------------
# Crie as credenciais em https://console.cloud.google.com/apis/credentials
# Callback: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- OAuth GitHub (opcional) -------------------------------------------------
# Crie um OAuth App em https://github.com/settings/developers
# Callback: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# --- Provedores de IA (Fase 2B) ----------------------------------------------
# Groq Cloud: https://console.groq.com/keys
GROQ_API_KEY=""
# Google AI Studio: https://aistudio.google.com/apikey (aceita as novas keys "AQ.")
GOOGLE_GENERATIVE_AI_API_KEY=""
