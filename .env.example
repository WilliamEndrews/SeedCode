# =============================================================================
# Variáveis de ambiente do SeedCode
# -----------------------------------------------------------------------------
# Copie este arquivo para `.env.local` e preencha os valores.
# =============================================================================

# Segredo usado pelo NextAuth para assinar os tokens de sessão (JWT).
# Gere um valor seguro com:  npx auth secret   (ou)  openssl rand -base64 32
AUTH_SECRET="troque-por-um-segredo-aleatorio"

# --- OAuth Google (opcional) -------------------------------------------------
# Crie as credenciais em https://console.cloud.google.com/apis/credentials
# Callback: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- OAuth GitHub (opcional) -------------------------------------------------
# Crie um OAuth App em https://github.com/settings/developers
# Callback: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# --- Provedores de IA (Fase 2B) ----------------------------------------------
# Groq Cloud: https://console.groq.com/keys
GROQ_API_KEY=""
# Google AI Studio: https://aistudio.google.com/apikey (aceita as novas keys "AQ.")
GOOGLE_GENERATIVE_AI_API_KEY=""

# --- Deploy e integrações (Etapa 2) ------------------------------------------
# Vercel: https://vercel.com/account/settings/tokens
# Crie um token com escopo "Create deployments" (full account ou team).
VERCEL_API_TOKEN=""

# (Opcional) ID da equipe Vercel, se o token for de uma organização.
# VERCEL_TEAM_ID=""

# GitHub: https://github.com/settings/tokens
# Token clássico (classic) com escopo "repo" para repositórios privados,
# ou "public_repo" para repositórios públicos.
GITHUB_TOKEN=""

# --- Banco de dados: Supabase / PostgreSQL (Etapa 1) -------------------------
# No painel do Supabase: Project Settings > Database > Connection string.
# DATABASE_URL usa o pooler (Transaction, porta 6543) com pgbouncer — usado pela
# aplicação em runtime. DIRECT_URL usa a conexão direta (porta 5432) — usada
# pelo Prisma Migrate. Substitua [PASSWORD] e [PROJECT-REF] pelos seus valores.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
